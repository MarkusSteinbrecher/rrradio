{
  "name": "internet-radio",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "node tools/build-catalog.mjs && vite",
    "build": "node tools/build-catalog.mjs && tsc && vite build && node tools/build-station-pages.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "catalog": "node tools/build-catalog.mjs",
    "probe": "node tools/probe-station.mjs",
    "candidates": "node tools/candidates.mjs",
    "validate-catalog": "node tools/validate-catalog.mjs",
    "check-drift": "node tools/check-drift.mjs",
    "check-duplicates": "node tools/check-duplicates.mjs",
    "auto-curate": "node tools/auto-curate.mjs",
    "analyze": "node tools/analyze.mjs",
    "backlog": "node tools/backlog.mjs",
    "import-ard": "node tools/import-ard.mjs",
    "backfill-geo": "node tools/backfill-geo.mjs",
    "wire-metadata": "node tools/wire-metadata.mjs",
    "sample-icy": "node tools/sample-icy.mjs",
    "gemma-label-icy": "node tools/gemma-label-icy.mjs",
    "evaluate-icy-parser": "node tools/evaluate-icy-parser.mjs",
    "discover-metadata": "node tools/discover-metadata-api.mjs"
  },
  "dependencies": {
    "hls.js": "^1.5.17",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "happy-dom": "^20.9.0",
    "playwright": "^1.59.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.5",
    "yaml": "^2.8.3"
  }
